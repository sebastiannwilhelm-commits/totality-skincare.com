# Copy to .env.local and fill values (never commit secrets).

# App (set to your Vercel URL in production so metadata/redirects resolve correctly)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase Auth (storefront login/signup)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Supabase (Auth + DB for leads, quiz, loyalty, orders)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
#
# Sign-up / email links: In Supabase Dashboard → Authentication → URL Configuration:
# - Site URL: your production origin (e.g. https://your-project.vercel.app or custom domain)
# - Redirect URLs: add each origin you use, plus the auth callback path, e.g.
#   https://your-domain.com/auth/callback
#   http://localhost:3000/auth/callback
# (Wildcard https://*.vercel.app is optional for preview deploys.)
# Email confirmation uses emailRedirectTo → /auth/callback?next=... so the callback URL must be allowed.

# Stripe Checkout + webhooks + Billing portal
# Test mode: Dashboard → Developers → API keys → use keys prefixed with sk_test_ / pk_test_ (publishable key is only needed if you add client-side Stripe later).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Recurring “club” price from Stripe Dashboard (recurring price id)
STRIPE_SUBSCRIPTION_PRICE_ID=

# Cart checkout calls /api/checkout/create-session, which reads product rows from Supabase with the service role — STRIPE_SECRET_KEY alone is not enough without NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY.

# Admin (Firebase storefront + Supabase RLS)
# Option A — Supabase Auth user: after that user exists in auth.users, grant in SQL editor:
#   insert into public.admin_roles (user_id) values ('<auth.users uuid>');
#
# Option B — Firebase sign-in to /admin (REQUIRED on Vercel for Firebase admin login):
#   1. All four NEXT_PUBLIC_FIREBASE_* variables above (client Firebase Auth)
#   2. ADMIN_EMAILS — comma-separated allowlist (emails are lowercased automatically)
#   3. ADMIN_SESSION_SECRET — long random string used only to sign the httpOnly admin cookie
#      (generate locally: openssl rand -hex 32)
# After sign-in, POST /api/admin/firebase-session sets the cookie; without both server vars, sign-in fails.
ADMIN_EMAILS=
# Optional if SUPABASE_SERVICE_ROLE_KEY is already set (used as signing fallback for admin cookie).
ADMIN_SESSION_SECRET=

# Transactional email (order confirmation, shipped, Rx status) — no-op if unset
RESEND_API_KEY=
RESEND_FROM_EMAIL=Totality Skincare <orders@yourdomain.com>

# SMS (optional) — no-op if unset
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=

# Shipping labels (Phase 3 — paste tracking in admin until Shippo UI ships)
SHIPPO_API_KEY=
