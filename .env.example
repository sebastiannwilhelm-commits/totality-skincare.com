# Copy to .env.local and fill values (never commit secrets).

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Auth + DB for leads, quiz, loyalty, orders)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe Checkout + webhooks + Billing portal
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Recurring “club” price from Stripe Dashboard (recurring price id)
STRIPE_SUBSCRIPTION_PRICE_ID=

# First admin user: after signup, run in SQL editor:
# insert into public.admin_roles (user_id) values ('<your auth.users id>');

# Resend / Twilio / Shippo (later phases)
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
SHIPPO_API_KEY=
